# ThreatFox API Configuration
# Get your API key from: https://threatfox.abuse.ch
THREATFOX_AUTH_KEY=your-threatfox-api-key-here

# SentinelOne Configuration
S1_CONSOLE_URL=https://usea1-020.sentinelone.net
S1_API_TOKEN=your-s1-api-token-here

# SentinelOne Scope (choose one or both)
S1_ACCOUNT_ID=2145017911777943699    # Account ID for account-level imports
# S1_SITE_ID=1234567890              # Site ID for site-level imports (optional)

# Import Configuration
MIN_CONFIDENCE=90                      # Minimum ThreatFox confidence threshold
IOC_MAX_AGE_HOURS=24                  # Fetch indicators from past N hours

# IOC Type-Specific Expiration (days after import)
IP_EXPIRATION_DAYS=7
DOMAIN_EXPIRATION_DAYS=14
URL_EXPIRATION_DAYS=14
HASH_EXPIRATION_DAYS=30

# Safety Limits
MAX_IMPORTS_PER_RUN=250               # Maximum IOCs to import in a single run
BATCH_SIZE=25                         # IOCs per POST request

# Operational Configuration
LOG_LEVEL=INFO                        # DEBUG, INFO, WARNING, ERROR
STATE_DB=threatfox_s1.db              # SQLite database file
DRY_RUN=true                          # **IMPORTANT: Set to false to enable actual writes**

# Logging
LOG_DIR=logs
LOG_FORMAT=json                       # json or text
